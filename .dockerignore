*.png
*.log

# Local PHP dev helpers not needed in the container
dev-router.php
run-dev-server.sh
dev-setup.sh
install-php.sh
test-db.sh
test-db-connection.php

# Python tooling (import is run on the host, not in the web container)
tools
__pycache__
*.pyc

# ...but DO ship the generic "No Image" placeholder (not PII)
!public/uploads/faceplaceholder.png
