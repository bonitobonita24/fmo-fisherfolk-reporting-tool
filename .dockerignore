# VCS / IDE
.git
.github
.gitignore
.vscode
.idea

# Claude / tooling artifacts
.claude
.playwright-mcp

# Source data & backups — never bake PII into image layers
masterlist
*.zip
data
public/uploads

# Login credential (provided at runtime via bind mount / env, never in the image)
config/auth.php

